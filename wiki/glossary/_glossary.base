views:
  - type: table
    name: Table
    filters:
      and:
        - file.hasTag("__CONCEPT", "__DEFINITION", "__EXECUTABLE")
    order:
      - file.name
      - depth
      - risk
      - tags
    sort:
      - property: depth
        direction: ASC
    columnSize:
      file.name: 469
      note.depth: 88
      note.risk: 94
